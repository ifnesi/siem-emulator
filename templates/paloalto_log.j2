{#- App/service map for protocol/port correlation -#}
{%- set app_map = {
    'dns':           {'proto': 'udp', 'dport': 53,   'category': 'networking'},
    'web-browsing':  {'proto': 'tcp', 'dport': 80,   'category': 'general-internet'},
    'ssl':           {'proto': 'tcp', 'dport': 443,  'category': 'networking'},
    'smtp':          {'proto': 'tcp', 'dport': 25,   'category': 'email'},
    'smtps':         {'proto': 'tcp', 'dport': 465,  'category': 'email'},
    'imap':          {'proto': 'tcp', 'dport': 143,  'category': 'email'},
    'ssh':           {'proto': 'tcp', 'dport': 22,   'category': 'networking'},
    'rdp':           {'proto': 'tcp', 'dport': 3389, 'category': 'business-systems'},
    'ntp':           {'proto': 'udp', 'dport': 123,  'category': 'networking'},
    'ldap':          {'proto': 'tcp', 'dport': 389,  'category': 'networking'},
    'kerberos':      {'proto': 'tcp', 'dport': 88,   'category': 'networking'},
    'msrpc':         {'proto': 'tcp', 'dport': 135,  'category': 'networking'},
    'ms-ds-replication': {'proto': 'tcp', 'dport': 389, 'category': 'networking'}
} -%}
{%- set app_key = randoms('dns|dns|web-browsing|web-browsing|ssl|ssl|ssl|smtp|smtps|imap|ssh|rdp|ntp|ldap|kerberos|msrpc|ms-ds-replication') -%}
{%- set app = app_map[app_key] -%}

{%- set usernames = ['jsmith', 'mjohnson', 'alee', 'kwilson', 'bmartin', 'cdavis', 'rthomas', 'ltaylor', 'pjackson', 'nwhite', 'sservice', 'backup-svc', 'scan-agent'] -%}
{%- set srcuser = 'CORP\\' + randoms(usernames) -%}

{%- set log_kind = randoms('traffic_end|traffic_end|traffic_end|traffic_start|traffic_deny|threat_virus|threat_spyware|threat_vuln|threat_url|system_gen|auth_login|globalprotect') -%}

{%- set _ts_now  = strftime('%Y/%m/%d %H:%M:%S') -%}
{%- set _ts_sys  = strftime('%b %d %H:%M:%S') -%}
{%- set _seqno   = integer(1000000000, 9999999999) -%}
{%- set _sessid  = integer(100000, 9999999) -%}
{%- set _sport   = integer(1024, 65535) -%}
{%- set _bytes   = integer(500, 10485760) -%}
{%- set _bs      = integer(200, 5242880) -%}
{%- set _br      = integer(200, 5242880) -%}
{%- set _pkts    = integer(2, 50000) -%}
{%- set _pks     = integer(1, 25000) -%}
{%- set _pkr     = integer(1, 25000) -%}
{%- set _elapsed = integer(1, 3600) -%}
{%- set _rule    = randoms('Allow-Outbound|Allow-Web|Block-Threat|Allow-Internal|Deny-All|Allow-DNS|Allow-Email') -%}
{%- set _dstip   = randoms('8.8.8.8|1.1.1.1|93.184.216.34|142.250.80.46|104.18.2.119|151.101.1.140|52.94.236.248') -%}
{%- set _dstloc  = randoms('US|GB|DE|JP|SG|AU|FR|NL|CA|IN') -%}

{%- set n = namespace(
    log_type='TRAFFIC',
    subtype='end',
    action='allow',
    flags='0x400050',
    suffix=''
) -%}

{%- if log_kind == 'traffic_end' -%}
    {#- namespace defaults cover this -#}
{%- elif log_kind == 'traffic_start' -%}
    {%- set n.subtype = 'start' -%}
{%- elif log_kind == 'traffic_deny' -%}
    {%- set n.subtype = 'deny' -%}
    {%- set n.action = 'deny' -%}
    {%- set n.flags = '0x400000' -%}

{%- elif log_kind == 'threat_virus' -%}
    {%- set n.log_type = 'THREAT' -%}
    {%- set n.subtype = 'virus' -%}
    {%- set n.action = 'reset-both' -%}
    {%- set n.flags = '0x402000' -%}
    {%- set n.suffix = randoms('eicar.com|malware_sample.exe|trojan_dropper.doc|ransomware.zip') + ',9999991,virus,' + randoms('critical|high') + ',client-to-server,' + _seqno|string + ',0x0,192.168.0.0-192.168.255.255,' + _dstloc + ',0,application/octet-stream,0,,,,,,,,0,0,0,0,vsys1,' + devname + ',from-policy,,,0,,0,,N/A,unknown,unknown,unknown,0x0' -%}

{%- elif log_kind == 'threat_spyware' -%}
    {%- set n.log_type = 'THREAT' -%}
    {%- set n.subtype = 'spyware' -%}
    {%- set n.action = 'alert' -%}
    {%- set n.flags = '0x402000' -%}
    {%- set n.suffix = randoms('c2.badactor.net/beacon|exfil.evil.com/upload') + ',20001,' + randoms('spyware|command-and-control') + ',' + randoms('high|critical') + ',client-to-server,' + _seqno|string + ',0x0,192.168.0.0-192.168.255.255,' + _dstloc + ',0,,0,,,,,,,,0,0,0,0,vsys1,' + devname + ',from-policy,,,0,,0,,N/A,unknown,unknown,unknown,0x0' -%}

{%- elif log_kind == 'threat_vuln' -%}
    {%- set n.log_type = 'THREAT' -%}
    {%- set n.subtype = 'vulnerability' -%}
    {%- set n.action = 'reset-server' -%}
    {%- set n.flags = '0x402000' -%}
    {%- set n.suffix = randoms('CVE-2021-44228|CVE-2023-44487|CVE-2022-0847') + ',' + randoms('30001|30002|30003') + ',vulnerability,' + randoms('critical|high|medium') + ',client-to-server,' + _seqno|string + ',0x0,192.168.0.0-192.168.255.255,' + _dstloc + ',0,,0,,,,,,,,0,0,0,0,vsys1,' + devname + ',from-policy,,,0,,0,,N/A,unknown,unknown,unknown,0x0' -%}

{%- elif log_kind == 'threat_url' -%}
    {%- set n.log_type = 'THREAT' -%}
    {%- set n.subtype = 'url' -%}
    {%- set n.action = 'block-url' -%}
    {%- set n.flags = '0x402000' -%}
    {%- set n.suffix = randoms('http://malware.example.com/payload|http://phishing.evil.net/login|http://adware.bad.org/click') + ',34999,url,' + randoms('high|medium') + ',client-to-server,' + _seqno|string + ',0x0,192.168.0.0-192.168.255.255,' + _dstloc + ',0,text/html,0,,,,,,,,0,0,0,0,vsys1,' + devname + ',from-policy,,,0,,0,,N/A,unknown,unknown,unknown,0x0' -%}

{%- elif log_kind == 'system_gen' -%}
    {%- set n.log_type = 'SYSTEM' -%}
    {%- set n.subtype = 'general' -%}
    {%- set n.action = '' -%}
    {%- set n.suffix = randoms('Configuration committed by admin|License expires in 30 days|HA peer became passive|Threat signature database updated|Device rebooted by admin') + ',' + _seqno|string + ',0x0,0,0,0,0,vsys1,' + devname -%}

{%- elif log_kind == 'auth_login' -%}
    {%- set n.log_type = 'AUTH' -%}
    {%- set n.subtype = 'auth' -%}
    {%- set n.action = randoms('authenticated|failed|timed-out') -%}
    {%- set n.suffix = randoms('sso|ldap|radius|local') + ',' + _seqno|string + ',0x0,vsys1,' + devname -%}

{%- elif log_kind == 'globalprotect' -%}
    {%- set n.log_type = 'GLOBALPROTECT' -%}
    {%- set n.subtype = 'globalprotect' -%}
    {%- set n.action = randoms('connect|disconnect|tunnel-reconnect') -%}
    {%- set n.suffix = randoms('gateway-connected|gateway-disconnected|tunnel-setup|tunnel-teardown') + ',' + _seqno|string + ',0x0,' + randoms('Windows|macOS|Linux|iOS|Android') + ',GP-GW-01,vsys1,' + devname -%}
{%- endif -%}

{#- Common fields for TRAFFIC and THREAT logs -#}
{%- if n.log_type in ['TRAFFIC', 'THREAT'] -%}
{{ _ts_sys }} 1,{{ _ts_now }},{{ pool('paloaltos', devname, 'serial') }},{{ n.log_type }},{{ n.subtype }},1,{{ _ts_now }},{{ pool('paloaltos', devname, 'srcip') }},{{ _dstip }},{{ pool('paloaltos', devname, 'natip') }},{{ _dstip }},{{ _rule }},{{ srcuser }},,{{ app_key }},{{ pool('paloaltos', devname, 'vsys') }},{{ pool('paloaltos', devname, 'src_zone') }},{{ pool('paloaltos', devname, 'dst_zone') }},{{ pool('paloaltos', devname, 'inbound_if') }},{{ pool('paloaltos', devname, 'outbound_if') }},Panorama-Log,{{ _ts_now }},{{ _sessid }},1,{{ _sport }},{{ app.dport }},{{ _sport }},{{ app.dport }},{{ n.flags }},{{ app.proto }},{{ n.action }},{% if n.log_type == 'TRAFFIC' %}{{ _bytes }},{{ _bs }},{{ _br }},{{ _pkts }},{{ _ts_now }},{{ _elapsed }},{{ app.category }},0,{{ _seqno }},0x0,{{ pool('paloaltos', devname, 'src_loc') }},{{ _dstloc }},0,{{ _pks }},{{ _pkr }},aged-out,{{ pool('paloaltos', devname, 'dg') }},0,0,0,vsys1,{{ devname }},from-policy,,,0,,0,,N/A,unknown,unknown,unknown,0x0{% else %}{{ n.suffix }}{% endif %}
{%- elif n.log_type == 'SYSTEM' -%}
{{ _ts_sys }} 1,{{ _ts_now }},{{ pool('paloaltos', devname, 'serial') }},SYSTEM,general,1,{{ _ts_now }},{{ pool('paloaltos', devname, 'vsys') }},{{ randoms('INFO|WARNING|ERROR|DEBUG') }},{{ randoms('general|auth|config|ha|uid|iot') }},{{ n.suffix }}
{%- elif n.log_type == 'AUTH' -%}
{{ _ts_sys }} 1,{{ _ts_now }},{{ pool('paloaltos', devname, 'serial') }},AUTH,auth,1,{{ _ts_now }},{{ pool('paloaltos', devname, 'srcip') }},{{ srcuser }},{{ n.action }},{{ n.suffix }}
{%- elif n.log_type == 'GLOBALPROTECT' -%}
{{ _ts_sys }} 1,{{ _ts_now }},{{ pool('paloaltos', devname, 'serial') }},GLOBALPROTECT,globalprotect,1,{{ _ts_now }},{{ pool('paloaltos', devname, 'srcip') }},{{ srcuser }},{{ n.action }},{{ n.suffix }}
{%- endif %}
