{
  "timestamp": {{ now() }},
  "capture_id": {{ random_string_vocabulary(12, 16, "0123456789abcdef") | tojson }},
  "frame_number": {{ integer(1, 999999) }},
  "frame_length": {{ integer(64, 1518) }},
  "capture_interface": {{ randoms("eth0|eth1|eth2|ens33|ens192|bond0|br0") | tojson }},
  "src_ip": {{ ip("10.10.0.0/16") | tojson }},
  "dst_ip": {{ ip("10.20.0.0/16") | tojson }},
  "src_port": {{ integer(1024, 65535) }},
  "dst_port": {{ randoms(data.known_ports) | int }},
  "protocol": {{ randoms("TCP|TCP|TCP|TCP|TCP|UDP|UDP|ICMP|GRE") | tojson }},
  "protocol_number": {{ integer(1, 255) }},
  "ip_version": {{ randoms("4|4|4|4|6") | int }},
  "ttl": {{ integer(32, 128) }},
  "ip_flags": {{ randoms("DF|MF|DF MF|none") | tojson }},
  "fragment_offset": {{ integer(0, 8192) }},
  "tcp_flags": {{ randoms("SYN|SYN ACK|ACK|PSH ACK|FIN ACK|RST|RST ACK|none") | tojson }},
  "tcp_seq": {{ integer(0, 4294967295) }},
  "tcp_ack": {{ integer(0, 4294967295) }},
  "tcp_window_size": {{ integer(512, 65535) }},
  "bytes_sent": {{ integer(64, 65535) }},
  "packets_sent": {{ integer(1, 1000) }},
  "src_mac": "{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}",
  "dst_mac": "{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}:{{ random_string_vocabulary(2, 2, "0123456789abcdef") }}",
  "vlan_id": {{ integer(1, 4094) }},
  "gateway": {{ randoms("10.10.0.1|10.10.1.1|10.10.2.1|10.20.0.1|192.168.0.1|192.168.1.1|172.16.0.1") | tojson }},
  "src_hostname": {{ randoms("web-server-01|web-server-02|app-server-01|app-server-02|db-server-01|db-server-02|workstation-101|workstation-102|laptop-201|laptop-202|mobile-301|iot-device-401") | tojson }},
  "dst_hostname": {{ randoms("api-gateway|load-balancer|database-primary|cache-server|file-server|mail-server|dns-server|proxy-server|internet|cloud-service|cdn-node|external-api") | tojson }},
  "application": {{ randoms("HTTP|HTTPS|SSH|FTP|DNS|SMTP|MySQL|PostgreSQL|Redis|Elasticsearch|Kafka|RabbitMQ|MongoDB|Cassandra|Unknown") | tojson }},
  "application_category": {{ randoms("Web|Database|Email|File-Transfer|Messaging|Streaming|Remote-Access|Cloud|API|Unknown") | tojson }},
  "connection_state": {{ randoms("ESTABLISHED|SYN_SENT|SYN_RECEIVED|FIN_WAIT|CLOSE_WAIT|TIME_WAIT|CLOSED|LISTEN") | tojson }},
  "direction": {{ randoms("inbound|outbound|internal|external") | tojson }},
  "geo_src_country": {{ randoms(data.countries) | tojson }},
  "geo_dst_country": {{ randoms(data.countries) | tojson }},
  "latency_ms": {{ integer(1, 500) }},
  "retransmissions": {{ integer(0, 10) }},
  "packet_loss": {{ integer(0, 5) }},
  "jitter_ms": {{ integer(0, 50) }}
}
