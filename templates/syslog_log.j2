{%- set server_configs = {
    'web-server-01': {'ip_address': '10.10.1.10'},
    'web-server-02': {'ip_address': '10.10.1.20'},
    'app-server-01': {'ip_address': '10.10.2.10'},
    'app-server-02': {'ip_address': '10.10.2.20'},
    'db-server-01': {'ip_address': '10.10.3.10'},
    'db-server-02': {'ip_address': '10.10.3.20'},
    'mail-server-01': {'ip_address': '172.16.0.10'},
    'dns-server-01': {'ip_address': '172.16.1.10'},
    'proxy-server-01': {'ip_address': '192.168.1.10'},
    'jump-host-01': {'ip_address': '192.168.2.10'},
    'k8s-master-01': {'ip_address': '10.10.4.10'},
    'k8s-worker-01': {'ip_address': '10.10.4.20'},
    'k8s-worker-02': {'ip_address': '10.10.4.30'},
    'jenkins-01': {'ip_address': '10.10.5.10'},
    'gitlab-01': {'ip_address': '10.10.5.20'},
    'monitoring-01': {'ip_address': '10.10.6.10'}
} -%}
{%- set _ = init_pool('servers', server_configs) -%}
{%- set hostname = randoms(server_configs.keys()|list) -%}
{
  "timestamp": {{ now() }},
  "hostname": {{ hostname | tojson }},
  "ip_address": {{ pool('servers', hostname, 'ip_address') | tojson }},
  "facility": {{ randoms("kern|user|mail|daemon|auth|syslog|lpr|news|uucp|cron|authpriv|ftp|local0|local1|local2|local3|local4|local5|local6|local7") | tojson }},
  "severity": {{ randoms("emerg|alert|crit|err|warning|notice|info|info|info|info|debug") | tojson }},
  "severity_code": {{ integer(0, 7) }},
  "priority": {{ integer(0, 191) }},
  "process_name": {{ randoms("sshd|systemd|kernel|cron|postfix|nginx|apache2|mysqld|postgres|docker|kubelet|containerd|rsyslogd|auditd|firewalld|NetworkManager|dhclient|ntpd") | tojson }},
  "process_id": {{ integer(1, 65535) }},
  "message_id": {{ random_string_vocabulary(8, 12, "0123456789ABCDEF") | tojson }},
  "structured_data": {{ randoms("-|-|[timeQuality tzKnown=1 isSynced=1]|[origin software=rsyslogd swVersion=8.2]|[meta sequenceId=123]") | tojson }},
  "message": {{ randoms("User login successful|User logout|Authentication failure|Connection established|Connection closed|Service started|Service stopped|Configuration reloaded|Disk space low|Memory usage high|CPU usage high|Network interface down|Network interface up|Backup completed|Backup failed|Certificate expiring soon|SSL handshake failed|Database connection lost|Database connection restored|Cache cleared|Session expired|File not found|Permission denied|Invalid request|Rate limit exceeded|Health check passed|Health check failed|Deployment started|Deployment completed|Deployment failed|Container started|Container stopped|Pod created|Pod deleted|Node ready|Node not ready") | tojson }},
  "source_ip": {{ randoms("10.10.1.45|10.10.2.67|192.168.1.100|172.16.0.50|203.0.113.45|198.51.100.23") | tojson }},
  "user": {{ randoms("root|admin|sysadmin|operator|service|nobody|www-data|nginx|mysql|postgres|redis|elasticsearch|kafka|jenkins|gitlab|prometheus") | tojson }},
  "event_type": {{ randoms("authentication|authorization|system|application|security|network|database|service|deployment|monitoring") | tojson }},
  "protocol": {{ randoms("syslog|rsyslog|syslog-ng|RFC5424|RFC3164|CEF|LEEF") | tojson }},
  "version": {{ randoms("1|2|3") | tojson }},
  "tags": {{ randoms("production|staging|development|critical|warning|info|security|audit|compliance|performance") | tojson }}
}
