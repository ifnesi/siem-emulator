{%- set device_configs = {} -%}
{%- for i in range(0, 50) -%}
    {%- set device_id = "IOT-DEV-%03d"|format(i) -%}
    {%- set _ = device_configs.update({
        device_id: {
            'location': regex("Building \\d{1} - Floor [A-E]"),
            'firmware_version': randoms("1.0.0|1.0.1|1.1.0|1.2.0|2.0.0|2.1.0"),
            'network_type': randoms("WiFi|LoRaWAN|Zigbee|Bluetooth|Ethernet|Cellular"),
            'ip_address': ip("10.20.0.0/16"),
            'mac_address': regex("[0-9A-F]{2}:[0-9A-F]{2}:[0-9A-F]{2}:[0-9A-F]{2}:[0-9A-F]{2}:[0-9A-F]{2}"),
            'manufacturer': randoms("SensorTech Inc|IoT Solutions Ltd|SmartDevice Corp|EnviroSense|TempMaster|ClimateControl Systems"),
            'model': randoms("ST-100|ST-200|IOT-ENV-PRO|TM-500|CC-1000|ES-300"),
            'baseline_temperature': gaussian(22.0, 5.0, 2),
            'baseline_humidity': gaussian(55.0, 15.0, 1),
            'baseline_pressure': gaussian(14.7, 0.2, 3),
            'baseline_battery': gaussian(75.0, 2, 2),
            'baseline_signal': gaussian(-65.0, 5.0, 1)
        }
    }) -%}
{%- endfor -%}
{%- set _ = init_pool('devices', device_configs) -%}
{%- set device_id = randoms(device_configs.keys()|list) -%}
{# Clamp bounds are floats so min()/max() never collapse a reading to a Python int #}
{# (which would make the field render as e.g. 90 instead of 90.0 and destabilise the #}
{# inferred Avro type between long and double). #}
{%- set new_temperature = pool('devices', device_id, 'baseline_temperature') + gaussian(0.0, 0.1, 2) -%}
{%- set new_humidity = min(90.0, max(5.0, pool('devices', device_id, 'baseline_humidity') + gaussian(0.0, 0.1, 1))) -%}
{%- set new_pressure = pool('devices', device_id, 'baseline_pressure') + gaussian(0.0, 0.05, 3) -%}
{# Battery only ever discharges: subtract a strictly positive drain so it trends down, not random-walks. #}
{%- set new_battery = min(99.0, max(5.0, pool('devices', device_id, 'baseline_battery') - (gaussian(0.02, 0.01, 3) | abs))) -%}
{%- set new_signal = pool('devices', device_id, 'baseline_signal') + gaussian(0.0, 0.1, 1) -%}
{%- set _ = update_pool('devices', device_id, 'baseline_temperature', new_temperature) -%}
{%- set _ = update_pool('devices', device_id, 'baseline_humidity', new_humidity) -%}
{%- set _ = update_pool('devices', device_id, 'baseline_pressure', new_pressure) -%}
{%- set _ = update_pool('devices', device_id, 'baseline_battery', new_battery) -%}
{%- set _ = update_pool('devices', device_id, 'baseline_signal', new_signal) -%}
{
    "timestamp": {{ now() }},
    "device_id": {{ device_id | tojson }},
    "location": {{ pool('devices', device_id, 'location') | tojson }},
    "firmware_version": {{ pool('devices', device_id, 'firmware_version') | tojson }},
    "network_type": {{ pool('devices', device_id, 'network_type') | tojson }},
    "ip_address": {{ pool('devices', device_id, 'ip_address') | tojson }},
    "mac_address": {{ pool('devices', device_id, 'mac_address') | tojson }},
    "manufacturer": {{ pool('devices', device_id, 'manufacturer') | tojson }},
    "model": {{ pool('devices', device_id, 'model') | tojson }},
    "temperature_celsius": {{ new_temperature | round(2) }},
    "humidity_percent": {{ new_humidity | round(1) }},
    "pressure_psi": {{ new_pressure | round(3) }},
    "battery_level": {{ new_battery | round(1) }},
    "signal_strength": {{ new_signal | round(1) }}
}